[include]
	path = ~/.config/delta/themes/catppuccin.gitconfig
	path = ~/.gitconfig.local
[color]
	ui = true
[pull]
	rebase = true
[rerere]
	enabled = true
[core]
	autocrlf = input
	editor = nvim
[init]
	defaultBranch = main
[delta]
	features = catppuccin-macchiato
[gpg]
	format = ssh
[commit]
	gpgsign = true
[tag]
	gpgsign = true
