#!/usr/bin/env bash
# workmux-pr — print a colored, grouped table of every workmux worktree PR,
# annotated with the live tmux session/window each worktree is open in.
# Reads the cache written by workmux-pr-poll; triggers a refresh if stale.
#
#   workmux-pr            pretty table (grouped by bucket)
#   workmux-pr --fzf      tab-separated rows for the fzf popup
#   workmux-pr --refresh  force a synchronous poll first
set -uo pipefail

export PATH="/opt/homebrew/bin:/opt/homebrew/sbin:/usr/bin:/bin:$HOME/.local/bin:$PATH"

CACHE="${WORKMUX_PR_CACHE:-$HOME/.cache/workmux-pr}"
TTL="${WORKMUX_PR_TTL:-300}"
POLLER="$HOME/.local/bin/workmux-pr-poll"
DATA="$CACHE/data.json"

mode="table"
case "${1:-}" in
  --fzf) mode="fzf" ;;
  --refresh) "$POLLER" ;;
esac

# Refresh in the background if stale (unless we just did it synchronously).
if [ "${1:-}" != "--refresh" ]; then
  stale=1
  if [ -f "$DATA" ]; then
    age=$(( $(date +%s) - $(stat -f %m "$DATA" 2>/dev/null || echo 0) ))
    [ "$age" -le "$TTL" ] && stale=0
  fi
  [ "$stale" -eq 1 ] && [ -x "$POLLER" ] && ( nohup "$POLLER" >/dev/null 2>&1 </dev/null & )
fi

if [ ! -f "$DATA" ]; then
  echo "No data yet — run 'workmux-pr --refresh' or wait for the poller."
  exit 0
fi

# Live map of worktree path -> tmux session/window (computed fresh, never cached,
# since the user moves windows around between polls).
panes="$(
  if command -v tmux >/dev/null 2>&1 && tmux info >/dev/null 2>&1; then
    tmux list-panes -a -F '#{pane_current_path}	#{session_name}	#{window_index}	#{window_name}' 2>/dev/null \
      | jq -R -s 'split("\n") | map(select(length > 0) | split("\t")
          | {path:.[0], session:.[1], window:.[2], wname:(.[3] | ltrimstr(" ") | ltrimstr("wm-"))})'
  else
    echo '[]'
  fi
)"

# jq helpers shared by both modes: locate a record's tmux window.
JQ_LOC='
  def locof:
    . as $r
    | ($panes | map(select(.path == $r.path or (.path | startswith($r.path + "/")))) | .[0]);
  def locstr:
    locof as $p | if $p then ($p.session + ":" + $p.window) else "(closed)" end;
  def emoji: {review_you:"👀", your_turn:"🔴", mergeable:"🟢",
              prunable:"🟣", waiting:"⚪", nopr:"⚫"}[.] // "•";
'

# Emit tab-separated rows for fzf:
#   emoji \t label(+location) \t url \t path \t repo_path \t handle \t session \t window
if [ "$mode" = "fzf" ]; then
  jq -r --argjson panes "$panes" "$JQ_LOC"'
    .[]
    | locof as $p
    | [ (.bucket|emoji),
        ((.repo) + "/" + (.handle)
          + (if .number then "  #\(.number) " + (.title // "") else "  (no PR)" end)
          + "  ⟶ " + (locstr)),
        (.url // ""), (.path // ""), (.repo_path // ""), (.handle // ""),
        (($p.session) // ""), (($p.window) // "")
      ] | @tsv
  ' "$DATA"
  exit 0
fi

# Pretty grouped table to stdout.
C_RESET=$'\033[0m'; C_DIM=$'\033[2m'; C_BOLD=$'\033[1m'
jq -r --argjson panes "$panes" "$JQ_LOC"'
  def blabel: {review_you:"REVIEW REQUESTED OF YOU", your_turn:"YOUR TURN",
              mergeable:"READY TO MERGE", prunable:"PRUNABLE (merged/closed)",
              waiting:"WAITING ON OTHERS", nopr:"NO PR"}[.] // .;
  def rank: {review_you:0, your_turn:1, mergeable:2, waiting:3, prunable:4, nopr:5}[.] // 9;
  (group_by(.bucket) | sort_by(.[0].bucket | rank)) as $groups
  | if ($groups|length) == 0 then "  (no worktrees found)"
    else
      $groups[] as $g
      | ("\n" + ($g[0].bucket|emoji) + "  " + ($g[0].bucket|blabel)),
        ( $g[] | "    " + .repo + "/" + .handle
                 + (if .number then "  #\(.number) " + (.title // "") else "  (no PR)" end)
                 + (if .checks == "fail" then "  ✗checks"
                    elif .checks == "pending" then "  ·checks" else "" end)
                 + (if .isDraft then "  [draft]" else "" end)
                 + "  ⟶ " + (locstr) )
    end
' "$DATA" | sed -E \
    -e "s/^(👀.*)$/${C_BOLD}\1${C_RESET}/" \
    -e "s/^(🔴.*)$/${C_BOLD}\1${C_RESET}/" \
    -e "s/(⟶ \(closed\))$/${C_DIM}\1${C_RESET}/"
