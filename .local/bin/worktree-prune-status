#!/usr/bin/env bash
# worktree-prune-status — fast tmux status reader for prunable worktrees.
# Prints the cached count instantly and spawns a background poll when stale.
set -uo pipefail

export PATH="/opt/homebrew/bin:/opt/homebrew/sbin:/usr/bin:/bin:$HOME/.local/bin:$PATH"

CACHE="${WORKTREE_PRUNE_CACHE:-$HOME/.cache/worktree-prune}"
TTL="${WORKTREE_PRUNE_TTL:-600}"
STATUS="$CACHE/status.txt"
DATA="$CACHE/data.json"
POLLER="$HOME/.local/bin/worktree-prune-poll"

# The prune segment is unobtrusive: it shows nothing when there is nothing to
# prune (empty cache), and "🧹N" only when worktrees can be cleaned up.
if [ -f "$STATUS" ]; then
  cat "$STATUS"
fi

stale=1
if [ -f "$DATA" ]; then
  age=$(( $(date +%s) - $(stat -f %m "$DATA" 2>/dev/null || echo 0) ))
  [ "$age" -le "$TTL" ] && stale=0
fi

if [ "$stale" -eq 1 ] && [ -x "$POLLER" ]; then
  ( nohup "$POLLER" >/dev/null 2>&1 </dev/null & )
fi
